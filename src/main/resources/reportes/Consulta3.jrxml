<jasperReport name="Consulta3" language="java" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="df189ed1-01ba-47c5-af3f-dc415c9db851">
	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="Sistema_Citas"/>
	<parameter name="logo" class="java.io.InputStream"/>
	<parameter name="p_dia_semana" class="java.lang.String"/>
	<parameter name="p_turno" class="java.lang.String"/>
	<parameter name="p_especialidad" class="java.lang.String"/>
	<query language="SQL"><![CDATA[SELECT 
  v.dia_semana AS diaSemana, 
  v.turno, 
  v.total_citas AS totalCitas, 
  v.ingresos_turno AS ingresosTurno, 
  ( 
    SELECT STRING_AGG(DISTINCT e.nombre, ', ') 
    FROM citas c 
    JOIN doctores d ON c.id_doctor = d.id_doctor 
    JOIN especialidades e ON d.id_especialidad = e.id_especialidad 
    WHERE c.estado != 'CANCELADA' 
      AND TO_CHAR(c.fecha_cita, 'TMDay') = v.dia_semana
      AND (
        (v.turno LIKE 'Mañana%' AND c.hora_cita < '12:00:00') OR 
        (v.turno LIKE 'Tarde%' AND c.hora_cita >= '12:00:00')
      )
      AND ($P{p_especialidad} = 'Todos' OR e.nombre = $P{p_especialidad})
  ) AS especialidades 
FROM public.vista_reporte_afluencia v 
WHERE ($P{p_dia_semana} = 'Todos' OR v.dia_semana = $P{p_dia_semana})
  AND ($P{p_turno} = 'Todos' OR v.turno LIKE CONCAT($P{p_turno}, '%'))
ORDER BY v.dia_semana, v.turno DESC]]></query>
